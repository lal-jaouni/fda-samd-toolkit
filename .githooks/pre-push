#!/bin/bash
# Pre-push hook: run full CI checks before pushing
# Prevents pushing code that will fail GitHub CI
echo "Running CI checks before push..."
make check 2>&1
status=$?
if [ $status -ne 0 ]; then
  echo ""
  echo "Push blocked: CI checks failed. Fix the issues above and try again."
  exit 1
fi
echo "All checks passed."
exit 0
